#include <stdio.h> 
#include <string.h>
int string length(char str[]) {
    int count = 0;
    for (int i = 0; str [i] != '\0'; i++) {
        count++;
    }
    return count;
}
void reverseString(char str[], char rev[]) {
    int len = stringLength(str);
    for (int i = 0; i < len; i++) {
        rev[i] = str[len - i - 1];
    }
    rev[len] = '\0';
} 
int isEqual(char str1[], char str2[]) {
    return strcmp(str1, str2) == 0;
}
 int isPalindrome(char str[]) {
    char rev[100];
    reverseString(str, rev);
    return strcmp(str, rev) == 0;
 } 
 int isSubstring(char str[], char sub[]) {
    return strstr(str, sub) != NULL;
 } 
 int main() {
    char str[100], str2[100], rev[100], sub[100];

    // Input string
    printf("Enter a string: ");
    gets(str);

    // Length
    printf("Length of string: %d\n", stringLength(str));

    // Reverse
    reverseString(str, rev);
    printf("Reversed string: %s\n", rev);

    // Equality check
    printf("Enter another string for comparison: ");
    gets(str2);
    if (isEqual(str, str2))
        printf("Strings are equal\n");
    else
        printf("Strings are not equal\n");

    // Palindrome check
    if (isPalindrome(str))
        printf("String is a palindrome\n");
    else
        printf("String is not a palindrome\n");

    // Substring check
    printf("Enter substring to check: ");
    gets(sub);
    if (isSubstring(str, sub))
        printf("Substring found\n");
    else
        printf("Substring not found\n");

    return 0;
}

